# =============================================================================
# 小苏 AI 助手 · 环境变量示例（.env.example）
# -----------------------------------------------------------------------------
# 用法：
#   1. 复制为 .env：cp .env.example .env
#   2. 将所有 replace_me 替换为真实值
# 红线：
#   - .env 绝不提交到 Git（已被 .gitignore 忽略）
#   - 日志中禁止明文打印 API Key / App Secret
#   - Web 设置页只展示「已配置 / 未配置」，不回显明文
# =============================================================================

# ---------- 应用 ----------
APP_NAME=xiaosu-ai-assistant
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------- 数据库（PostgreSQL 16 + pgvector）----------
# 说明：Docker Compose 模式下主机名用 postgres（compose service 名）；
#       本地 uvicorn 直连模式请把 postgres 改成 localhost。
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/xiaosu

# ---------- 缓存（Redis 7）----------
# Docker 模式用 redis，本地模式用 localhost
REDIS_URL=redis://redis:6379/0

# ---------- LLM（OpenAI 兼容接口，不绑定具体厂商）----------
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace_me
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# ---------- Embedding ----------
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=https://api.example.com/v1
EMBEDDING_API_KEY=replace_me
EMBEDDING_MODEL=text-embedding-3-small
# 向量维度必须与 document_chunks.embedding VECTOR(n) 严格一致
EMBEDDING_DIMENSION=1536

# ---------- RAG ----------
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.65
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120

# ---------- Agent 工具调用 ----------
MAX_TOOL_ROUNDS=3
TOOL_TIMEOUT_SECONDS=10

# ---------- 存储与上传 ----------
STORAGE_DIR=storage/uploads
LOG_DIR=logs
# 上传单文件大小上限（字节），默认 10MB
UPLOAD_MAX_SIZE_BYTES=10485760
# Web 后台地址，用于 IM 引用链接
WEB_BASE_URL=http://localhost:3001

# ---------- 钉钉机器人（IM 优先接入钉钉）----------
DINGTALK_APP_KEY=replace_me
DINGTALK_APP_SECRET=replace_me
DINGTALK_ROBOT_CODE=replace_me
DINGTALK_CALLBACK_TOKEN=replace_me
# 事件订阅加密回调 AES 密钥（43 字符 base64）；启用加密推送时填写
DINGTALK_AES_KEY=replace_me

# ---------- 飞书机器人（IM 第二渠道）----------
# FEISHU_ENCRYPT_KEY 用于事件回调的 AES-256-CBC 解密 + X-Lark-Signature 验签
# FEISHU_VERIFICATION_TOKEN 用于回调事件 header.token 校验
FEISHU_APP_ID=replace_me
FEISHU_APP_SECRET=replace_me
FEISHU_VERIFICATION_TOKEN=replace_me
FEISHU_ENCRYPT_KEY=replace_me
FEISHU_BASE_URL=https://open.feishu.cn/open-apis

# ---------- IM 与会话 ----------
IM_DEFAULT_TIMEOUT_SECONDS=45
CONVERSATION_MAX_TURNS=10

# ---------- 可观测性（可选，未配置时 noop）----------
LANGFUSE_PUBLIC_KEY=replace_me
LANGFUSE_SECRET_KEY=replace_me
LANGFUSE_HOST=

# ---------- 前端（Next.js）----------
# 必须以 NEXT_PUBLIC_ 为前缀，才会暴露给浏览器端
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
