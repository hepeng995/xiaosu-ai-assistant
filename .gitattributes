# ===========================================================================
# 统一文本文件换行符为 LF
# 避免 Windows 上 .sh 脚本（CRLF 会让 bash 报 "bad interpreter"）与
# Python/TS 源码的换行符混乱。
# ===========================================================================

# 默认自动判定，统一 LF
* text=auto eol=lf

# 脚本必须 LF（bash 不识别 CRLF）
*.sh text eol=lf

# 源码与配置统一 LF
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.txt text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.env.example text eol=lf

# 二进制文件（文档样本与图片，不做换行处理）
*.pdf binary
*.docx binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
